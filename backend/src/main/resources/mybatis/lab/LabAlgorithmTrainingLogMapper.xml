<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.lab.mapper.LabAlgorithmTrainingLogMapper">
    
    <resultMap type="LabAlgorithmTrainingLog" id="LabAlgorithmTrainingLogResult">
        <result property="trainingId"    column="training_id"    />
        <result property="algorithmType"    column="algorithm_type"    />
        <result property="taskName"    column="task_name"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="status"    column="status"    />
        <result property="trainingParams"    column="training_params"    />
        <result property="totalEpochs"    column="total_epochs"    />
        <result property="completedEpochs"    column="completed_epochs"    />
        <result property="lossValue"    column="loss_value"    />
        <result property="accuracy"    column="accuracy"    />
        <result property="modelVersion"    column="model_version"    />
        <result property="errorMessage"    column="error_message"    />
        <result property="metrics"    column="metrics"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLabAlgorithmTrainingLogVo">
        select training_id, algorithm_type, task_name, start_time, end_time, status, training_params, total_epochs, completed_epochs, loss_value, accuracy, model_version, error_message, metrics, create_by, create_time, update_by, update_time, remark from lab_algorithm_training_log
    </sql>

    <select id="selectLabAlgorithmTrainingLogList" parameterType="LabAlgorithmTrainingLog" resultMap="LabAlgorithmTrainingLogResult">
        <include refid="selectLabAlgorithmTrainingLogVo"/>
        <where>  
            <if test="algorithmType != null  and algorithmType != ''"> and algorithm_type = #{algorithmType}</if>
            <if test="taskName != null  and taskName != ''"> and task_name like concat('%', #{taskName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                and date_format(start_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                and date_format(start_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
        order by start_time desc
    </select>
    
    <select id="selectLabAlgorithmTrainingLogByTrainingId" parameterType="Long" resultMap="LabAlgorithmTrainingLogResult">
        <include refid="selectLabAlgorithmTrainingLogVo"/>
        where training_id = #{trainingId}
    </select>
        
    <insert id="insertLabAlgorithmTrainingLog" parameterType="LabAlgorithmTrainingLog" useGeneratedKeys="true" keyProperty="trainingId">
        insert into lab_algorithm_training_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="algorithmType != null and algorithmType != ''">algorithm_type,</if>
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="trainingParams != null">training_params,</if>
            <if test="totalEpochs != null">total_epochs,</if>
            <if test="completedEpochs != null">completed_epochs,</if>
            <if test="lossValue != null">loss_value,</if>
            <if test="accuracy != null">accuracy,</if>
            <if test="modelVersion != null and modelVersion != ''">model_version,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="metrics != null">metrics,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="algorithmType != null and algorithmType != ''">#{algorithmType},</if>
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="trainingParams != null">#{trainingParams},</if>
            <if test="totalEpochs != null">#{totalEpochs},</if>
            <if test="completedEpochs != null">#{completedEpochs},</if>
            <if test="lossValue != null">#{lossValue},</if>
            <if test="accuracy != null">#{accuracy},</if>
            <if test="modelVersion != null and modelVersion != ''">#{modelVersion},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="metrics != null">#{metrics},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateLabAlgorithmTrainingLog" parameterType="LabAlgorithmTrainingLog">
        update lab_algorithm_training_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="algorithmType != null and algorithmType != ''">algorithm_type = #{algorithmType},</if>
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="trainingParams != null">training_params = #{trainingParams},</if>
            <if test="totalEpochs != null">total_epochs = #{totalEpochs},</if>
            <if test="completedEpochs != null">completed_epochs = #{completedEpochs},</if>
            <if test="lossValue != null">loss_value = #{lossValue},</if>
            <if test="accuracy != null">accuracy = #{accuracy},</if>
            <if test="modelVersion != null and modelVersion != ''">model_version = #{modelVersion},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="metrics != null">metrics = #{metrics},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where training_id = #{trainingId}
    </update>

    <delete id="deleteLabAlgorithmTrainingLogByTrainingId" parameterType="Long">
        delete from lab_algorithm_training_log where training_id = #{trainingId}
    </delete>

    <delete id="deleteLabAlgorithmTrainingLogByTrainingIds" parameterType="Long">
        delete from lab_algorithm_training_log where training_id in 
        <foreach item="trainingId" collection="array" open="(" separator="," close=")">
            #{trainingId}
        </foreach>
    </delete>
</mapper>
