<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.lab.mapper.LabAlgorithmLogMapper">

    <resultMap type="LabAlgorithmLog" id="LabAlgorithmLogResult">
        <result property="logId" column="log_id"/>
        <result property="algorithmType" column="algorithm_type"/>
        <result property="operationType" column="operation_type"/>
        <result property="userId" column="user_id"/>
        <result property="params" column="params"/>
        <result property="result" column="result"/>
        <result property="status" column="status"/>
        <result property="errorMessage" column="error_message"/>
        <result property="durationMs" column="duration_ms"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectLabAlgorithmLogVo">
        select log_id, algorithm_type, operation_type, user_id, params, result, status, error_message, duration_ms, create_by, create_time, update_by, update_time, remark
        from lab_algorithm_log
    </sql>

    <select id="selectLabAlgorithmLogList" parameterType="LabAlgorithmLog" resultMap="LabAlgorithmLogResult">
        <include refid="selectLabAlgorithmLogVo"/>
        <where>
            <if test="algorithmType != null and algorithmType != ''">
                and algorithm_type = #{algorithmType}
            </if>
            <if test="operationType != null and operationType != ''">
                and operation_type = #{operationType}
            </if>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectLabAlgorithmLogByLogId" parameterType="Long" resultMap="LabAlgorithmLogResult">
        <include refid="selectLabAlgorithmLogVo"/>
        where log_id = #{logId}
    </select>

    <insert id="insertLabAlgorithmLog" parameterType="LabAlgorithmLog" useGeneratedKeys="true" keyProperty="logId">
        insert into lab_algorithm_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="algorithmType != null and algorithmType != ''">algorithm_type,</if>
            <if test="operationType != null and operationType != ''">operation_type,</if>
            <if test="userId != null">user_id,</if>
            <if test="params != null">params,</if>
            <if test="result != null">result,</if>
            <if test="status != null">status,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="durationMs != null">duration_ms,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="algorithmType != null and algorithmType != ''">#{algorithmType},</if>
            <if test="operationType != null and operationType != ''">#{operationType},</if>
            <if test="userId != null">#{userId},</if>
            <if test="params != null">#{params},</if>
            <if test="result != null">#{result},</if>
            <if test="status != null">#{status},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="durationMs != null">#{durationMs},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateLabAlgorithmLog" parameterType="LabAlgorithmLog">
        update lab_algorithm_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="algorithmType != null and algorithmType != ''">algorithm_type = #{algorithmType},</if>
            <if test="operationType != null and operationType != ''">operation_type = #{operationType},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="params != null">params = #{params},</if>
            <if test="result != null">result = #{result},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="durationMs != null">duration_ms = #{durationMs},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where log_id = #{logId}
    </update>

    <delete id="deleteLabAlgorithmLogByLogId" parameterType="Long">
        delete from lab_algorithm_log where log_id = #{logId}
    </delete>

    <delete id="deleteLabAlgorithmLogByLogIds" parameterType="String">
        delete from lab_algorithm_log where log_id in
        <foreach item="logId" collection="array" open="(" separator="," close=")">
            #{logId}
        </foreach>
    </delete>

</mapper>
