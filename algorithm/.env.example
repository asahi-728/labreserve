# GATv2 算法服务配置
# 复制此文件为 .env 并填入实际配置

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=labreserve
DB_CHARSET=utf8mb4

# ========== 模型配置 ==========
# 输入特征维度
MODEL_IN_CHANNELS=8
# 隐藏层维度
MODEL_HIDDEN_CHANNELS=16
# 输出嵌入维度
MODEL_OUT_CHANNELS=4
# 学习率
MODEL_LR=0.01
# 训练轮次
MODEL_EPOCHS=100

# ========== API 服务配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# ========== 推荐配置 ==========
# 默认推荐数量
RECOMMEND_TOP_K=5
# 是否排除已预约设备
RECOMMEND_EXCLUDE_RESERVED=True
# 是否排除维修中设备
RECOMMEND_EXCLUDE_MAINTENANCE=True

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_DIR=./logs
