<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.lab.mapper.LabReservationMapper">

    <resultMap type="LabReservation" id="LabReservationResult">
        <result property="reserveId"    column="reserve_id"    />
        <result property="userId"    column="user_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="status"    column="status"    />
        <result property="auditBy"    column="audit_by"    />
        <result property="auditTime"    column="audit_time"    />
        <result property="auditRemark"    column="audit_remark"    />
        <result property="schedulerType"    column="scheduler_type"    />
        <result property="cancelTime"    column="cancel_time"    />
        <result property="completeTime"    column="complete_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="remark"    column="remark"    />
        <result property="deviceName"    column="device_name"    />
        <result property="labName"    column="lab_name"    />
        <result property="location"    column="location"    />
    </resultMap>

    <sql id="selectLabReservationVo">
        select r.reserve_id, r.user_id, r.device_id, r.start_time, r.end_time, r.status, r.audit_by, r.audit_time, r.audit_remark, r.scheduler_type, r.cancel_time, r.complete_time, r.create_by, r.create_time, r.remark,
               d.device_name, l.lab_name, l.location
        from lab_reservation r
        left join lab_device d on r.device_id = d.device_id
        left join lab_laboratory l on d.lab_id = l.lab_id
    </sql>

    <select id="selectLabReservationList" parameterType="LabReservation" resultMap="LabReservationResult">
        <include refid="selectLabReservationVo"/>
        <where>
            <if test="userId != null "> and r.user_id = #{userId}</if>
            <if test="deviceId != null "> and r.device_id = #{deviceId}</if>
            <if test="categoryId != null "> and d.category_id = #{categoryId}</if>
            <if test="labId != null "> and d.lab_id = #{labId}</if>
            <if test="userName != null and userName != ''"> and r.create_by like concat('%', #{userName}, '%')</if>
            <if test="startTimeStr != null and startTimeStr != ''"> and DATE(r.start_time) &gt;= #{startTimeStr}</if>
            <if test="endTimeStr != null and endTimeStr != ''"> and DATE(r.end_time) &lt;= #{endTimeStr}</if>
            <if test="status != null  and status != ''"> and r.status = #{status}</if>
            <if test="auditBy != null  and auditBy != ''"> and r.audit_by = #{auditBy}</if>
            <if test="auditTime != null "> and r.audit_time = #{auditTime}</if>
            <if test="schedulerType != null  and schedulerType != ''"> and r.scheduler_type = #{schedulerType}</if>
        </where>
        order by r.create_time desc
    </select>

    <select id="selectMyReservationList" parameterType="LabReservation" resultMap="LabReservationResult">
        <include refid="selectLabReservationVo"/>
        <where>
            <if test="userId != null "> and r.user_id = #{userId}</if>
            <if test="labId != null "> and d.lab_id = #{labId}</if>
            <if test="startTimeStr != null and startTimeStr != ''"> and DATE(r.start_time) &gt;= #{startTimeStr}</if>
            <if test="endTimeStr != null and endTimeStr != ''"> and DATE(r.end_time) &lt;= #{endTimeStr}</if>
            <if test="status != null and status != ''"> and r.status = #{status}</if>
        </where>
        order by r.create_time desc
    </select>

    <select id="selectLabReservationByReserveId" parameterType="Long" resultMap="LabReservationResult">
        <include refid="selectLabReservationVo"/>
        where r.reserve_id = #{reserveId}
    </select>

    <insert id="insertLabReservation" parameterType="LabReservation" useGeneratedKeys="true" keyProperty="reserveId">
        insert into lab_reservation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="deviceId != null">device_id,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="auditBy != null and auditBy != ''">audit_by,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="auditRemark != null and auditRemark != ''">audit_remark,</if>
            <if test="schedulerType != null and schedulerType != ''">scheduler_type,</if>
            <if test="cancelTime != null">cancel_time,</if>
            <if test="completeTime != null">complete_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="deviceId != null">#{deviceId},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="auditBy != null and auditBy != ''">#{auditBy},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="auditRemark != null and auditRemark != ''">#{auditRemark},</if>
            <if test="schedulerType != null and schedulerType != ''">#{schedulerType},</if>
            <if test="cancelTime != null">#{cancelTime},</if>
            <if test="completeTime != null">#{completeTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateLabReservation" parameterType="LabReservation">
        update lab_reservation
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="auditBy != null and auditBy != ''">audit_by = #{auditBy},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditRemark != null">audit_remark = #{auditRemark},</if>
            <if test="schedulerType != null and schedulerType != ''">scheduler_type = #{schedulerType},</if>
            <if test="cancelTime != null">cancel_time = #{cancelTime},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where reserve_id = #{reserveId}
    </update>

    <delete id="deleteLabReservationByReserveId" parameterType="Long">
        delete from lab_reservation where reserve_id = #{reserveId}
    </delete>

    <delete id="deleteLabReservationByReserveIds" parameterType="String">
        delete from lab_reservation where reserve_id in
        <foreach item="reserveId" collection="array" open="(" separator="," close=")">
            #{reserveId}
        </foreach>
    </delete>

    <select id="selectConflictingReservations" resultMap="LabReservationResult">
        select reserve_id, user_id, device_id, start_time, end_time, status, audit_by, audit_time, audit_remark, scheduler_type, create_by, create_time, remark
        from lab_reservation
        where device_id = #{deviceId}
        and status in ('0', '1')
        <if test="excludeReserveId != null">
            and reserve_id != #{excludeReserveId}
        </if>
        and (
            (start_time &lt; #{endTime} and end_time &gt; #{startTime})
        )
    </select>
</mapper>
