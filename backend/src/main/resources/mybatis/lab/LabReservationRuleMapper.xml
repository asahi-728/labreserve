<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.lab.mapper.LabReservationRuleMapper">

    <resultMap type="LabReservationRule" id="LabReservationRuleResult">
        <result property="ruleId"       column="rule_id"       />
        <result property="ruleName"     column="rule_name"     />
        <result property="ruleKey"      column="rule_key"      />
        <result property="ruleValue"    column="rule_value"    />
        <result property="ruleType"     column="rule_type"     />
        <result property="description"  column="description"   />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectLabReservationRuleVo">
        select rule_id, rule_name, rule_key, rule_value, rule_type, description, status, create_by, create_time, update_by, update_time, remark
        from lab_reservation_rule
    </sql>

    <select id="selectLabReservationRuleList" parameterType="LabReservationRule" resultMap="LabReservationRuleResult">
        <include refid="selectLabReservationRuleVo"/>
        <where>
            <if test="ruleName != null and ruleName != ''"> and rule_name like concat('%', #{ruleName}, '%')</if>
            <if test="ruleKey != null and ruleKey != ''"> and rule_key = #{ruleKey}</if>
            <if test="ruleValue != null and ruleValue != ''"> and rule_value = #{ruleValue}</if>
            <if test="ruleType != null and ruleType != ''"> and rule_type = #{ruleType}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by rule_id asc
    </select>

    <select id="selectLabReservationRuleByRuleId" parameterType="Long" resultMap="LabReservationRuleResult">
        <include refid="selectLabReservationRuleVo"/>
        where rule_id = #{ruleId}
    </select>

    <select id="selectLabReservationRuleByRuleKey" parameterType="String" resultMap="LabReservationRuleResult">
        <include refid="selectLabReservationRuleVo"/>
        where rule_key = #{ruleKey}
    </select>

    <select id="selectLabReservationRuleByType" parameterType="String" resultMap="LabReservationRuleResult">
        <include refid="selectLabReservationRuleVo"/>
        where rule_type = #{ruleType}
        order by rule_id asc
    </select>

    <insert id="insertLabReservationRule" parameterType="LabReservationRule" useGeneratedKeys="true" keyProperty="ruleId">
        insert into lab_reservation_rule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">rule_name,</if>
            <if test="ruleKey != null and ruleKey != ''">rule_key,</if>
            <if test="ruleValue != null and ruleValue != ''">rule_value,</if>
            <if test="ruleType != null and ruleType != ''">rule_type,</if>
            <if test="description != null">description,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">#{ruleName},</if>
            <if test="ruleKey != null and ruleKey != ''">#{ruleKey},</if>
            <if test="ruleValue != null and ruleValue != ''">#{ruleValue},</if>
            <if test="ruleType != null and ruleType != ''">#{ruleType},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateLabReservationRule" parameterType="LabReservationRule">
        update lab_reservation_rule
        <trim prefix="SET" suffixOverrides=",">
            <if test="ruleName != null and ruleName != ''">rule_name = #{ruleName},</if>
            <if test="ruleKey != null and ruleKey != ''">rule_key = #{ruleKey},</if>
            <if test="ruleValue != null and ruleValue != ''">rule_value = #{ruleValue},</if>
            <if test="ruleType != null and ruleType != ''">rule_type = #{ruleType},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where rule_id = #{ruleId}
    </update>

    <delete id="deleteLabReservationRuleByRuleId" parameterType="Long">
        delete from lab_reservation_rule where rule_id = #{ruleId}
    </delete>

    <delete id="deleteLabReservationRuleByRuleIds" parameterType="String">
        delete from lab_reservation_rule where rule_id in
        <foreach item="ruleId" collection="array" open="(" separator="," close=")">
            #{ruleId}
        </foreach>
    </delete>

</mapper>
