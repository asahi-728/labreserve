<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.lab.mapper.LabDeviceMapper">
    
    <resultMap type="LabDevice" id="LabDeviceResult">
        <result property="deviceId"    column="device_id"    />
        <result property="deviceName"    column="device_name"    />
        <result property="categoryId"    column="category_id"    />
        <result property="labId"    column="lab_id"    />
        <result property="status"    column="status"    />
        <result property="specs"    column="specs"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectLabDeviceVo">
        select device_id, device_name, category_id, lab_id, status, specs, create_by, create_time, update_by, update_time, remark from lab_device
    </sql>

    <select id="selectLabDeviceList" parameterType="LabDevice" resultMap="LabDeviceResult">
        <include refid="selectLabDeviceVo"/>
        <where>  
            <if test="deviceName != null  and deviceName != ''"> and device_name like concat('%', #{deviceName}, '%')</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="labId != null "> and lab_id = #{labId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectLabDeviceByDeviceId" parameterType="Long" resultMap="LabDeviceResult">
        <include refid="selectLabDeviceVo"/>
        where device_id = #{deviceId}
    </select>

    <insert id="insertLabDevice" parameterType="LabDevice" useGeneratedKeys="true" keyProperty="deviceId">
        insert into lab_device
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceName != null and deviceName != ''">device_name,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="labId != null">lab_id,</if>
            <if test="status != null">status,</if>
            <if test="specs != null">specs,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceName != null and deviceName != ''">#{deviceName},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="labId != null">#{labId},</if>
            <if test="status != null">#{status},</if>
            <if test="specs != null">#{specs},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateLabDevice" parameterType="LabDevice">
        update lab_device
        <trim prefix="SET" suffixOverrides=",">
            <if test="deviceName != null and deviceName != ''">device_name = #{deviceName},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="labId != null">lab_id = #{labId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="specs != null">specs = #{specs},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where device_id = #{deviceId}
    </update>

    <delete id="deleteLabDeviceByDeviceId" parameterType="Long">
        delete from lab_device where device_id = #{deviceId}
    </delete>

    <delete id="deleteLabDeviceByDeviceIds" parameterType="String">
        delete from lab_device where device_id in 
        <foreach item="deviceId" collection="array" open="(" separator="," close=")">
            #{deviceId}
        </foreach>
    </delete>
</mapper>